# Local environment configuration.
# Copy this file to .env and adjust as needed.
# In production, set environment variables via server or container configuration instead.
APP_ENV=dev
APP_DEBUG=true

DB_HOST=mysql
DB_PORT=3306
DB_NAME=app
DB_USER=app
DB_PASSWORD=app

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis

QUEUE_WORKER_1_COMMAND=php /app/yii queue:work --sleep=3 --queue=mysql
QUEUE_WORKER_2_COMMAND=php /app/yii queue:work --sleep=3 --queue=mysql
