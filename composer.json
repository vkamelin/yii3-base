{
    "name": "vkamelin/yii3-base",
    "type": "project",
    "description": "Modular Yii3 application skeleton for ERP, CRM, SaaS and internal tools",
    "keywords": [
        "yii3",
        "php",
        "application-skeleton",
        "ddd",
        "clean-architecture",
        "modular-monolith",
        "erp",
        "crm",
        "saas",
        "rbac",
        "rest-api"
    ],
    "license": "proprietary",
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@php ./yii serve"
        ],
        "test": "codecept run",
        "migrate": "@php ./yii migrate:up",
        "migrate:down": "@php ./yii migrate:down",
        "test:unit": "codecept run Unit",
        "test:functional": "codecept run Functional",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "psalm": "psalm",
        "rector": "rector process --dry-run",
        "analyse": [
            "@psalm",
            "@cs",
            "composer dependency-analyser"
        ]
    },
    "require": {
        "php": "^8.4",
        "ext-filter": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-intl": "*",
        "ext-openssl": "*",
        "ext-ctype": "*",
        "ext-curl": "*",
        "httpsoft/http-message": "^1.1.6",
        "middlewares/http-authentication": "^2.2",
        "middlewares/uuid": "^2.1",
        "monolog/monolog": "^3.10",
        "psr/container": "^2.0.2",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0.2",
        "psr/log": "^3.0.2",
        "ramsey/uuid": "^4.9.2",
        "symfony/console": "^7.4.7 || ^8.0.8",
        "yiisoft/aliases": "^3.1.1",
        "yiisoft/assets": "^5.1.2",
        "yiisoft/auth": "^3.2.1",
        "yiisoft/cache": "^3.2",
        "yiisoft/cache-redis": "^2.0",
        "yiisoft/config": "^1.6.2",
        "yiisoft/csrf": "^2.2.3",
        "yiisoft/db-migration": "^2.0.1",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/definitions": "^3.4.1",
        "yiisoft/di": "^1.4.1",
        "yiisoft/error-handler": "^4.3.2",
        "yiisoft/form-model": "^1.1.1",
        "yiisoft/html": "^4",
        "yiisoft/http": "^1.3",
        "yiisoft/input-http": "^1.0.1",
        "yiisoft/log": "^2.2.1",
        "yiisoft/mailer": "^6.1",
        "yiisoft/middleware-dispatcher": "^5.4",
        "yiisoft/rbac": "^2.1.2",
        "yiisoft/request-provider": "^1.3",
        "yiisoft/router": "^4.0.2",
        "yiisoft/router-fastroute": "^4.0.3",
        "yiisoft/security": "^1.2",
        "yiisoft/session": "^3.0.1",
        "yiisoft/validator": "^2.5.1",
        "yiisoft/view": "^12.2.4",
        "yiisoft/yii-console": "^2.4.2",
        "yiisoft/yii-event": "^2.2",
        "yiisoft/yii-http": "^1.1.1",
        "yiisoft/yii-runner-console": "^2.2.1",
        "yiisoft/yii-runner-http": "^3.2.1",
        "yiisoft/yii-view-renderer": "^7.4.1"
    },
    "require-dev": {
        "codeception/c3": "^2.9",
        "codeception/codeception": "^5.3.5",
        "codeception/module-asserts": "^3.3.0",
        "codeception/module-cli": "^2.0.1",
        "codeception/module-phpbrowser": "^4",
        "deptrac/deptrac": "^4.6",
        "ergebnis/composer-normalize": "^2.51",
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "infection/infection": "^0.32.7",
        "phpstan/phpstan": "^2.1.51",
        "phpstan/phpstan-strict-rules": "^2.0.10",
        "phpunit/phpunit": "^11.5.55",
        "rector/rector": "^2.4.2",
        "roave/security-advisories": "dev-latest",
        "shipmonk/composer-dependency-analyser": "^1.8.4",
        "vimeo/psalm": "^6.16.1",
        "vlucas/phpdotenv": "^5.6.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Tests\\": "tests/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests"
        }
    },
    "extra": {
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true,
        "bump-after-update": true,
        "allow-plugins": {
            "codeception/c3": true,
            "composer/installers": true,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "yiisoft/config": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
